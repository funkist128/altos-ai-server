# Hugging Face token (gated 模型如 gemma 必須)
HF_TOKEN=hf_xxx_replace_me

# vLLM container image
# GB10 (aarch64 + Blackwell) 建議使用官方支援 ARM64 的 tag，或 NVIDIA NGC 版本
VLLM_IMAGE=vllm/vllm-openai:latest

# 模型 ID (HuggingFace repo)
LARGE_MODEL_ID=google/gemma-4-26B-A4B-it
SMALL_MODEL_ID=google/gemma-4-e4b-it

# 對外暴露的服務名稱 (router 與 Open WebUI 使用)
LARGE_MODEL_NAME=gemma-large
SMALL_MODEL_NAME=gemma-small

# 單一 GB10 GPU 上兩個模型共用記憶體的比例
# 26B (A4B MoE) 需較多權重空間，e4b 較小；剩餘給 KV cache + 系統
LARGE_GPU_MEM_UTIL=0.55
SMALL_GPU_MEM_UTIL=0.20

# 最大 context 長度
LARGE_MAX_LEN=8192
SMALL_MAX_LEN=8192

# Nginx 對外 port (唯一 entry，預設 80；若 80 已被佔用改成 8080 等)
NGINX_PORT=80
