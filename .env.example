# Hugging Face token (gated 模型如 gemma 必須)
HF_TOKEN=hf_xxx_replace_me

# vLLM container image
# GB10 (aarch64 + Blackwell) 建議使用官方支援 ARM64 的 tag，或 NVIDIA NGC 版本
VLLM_IMAGE=vllm/vllm-openai:latest

# 主模型 (目前只跑這一顆；命名沿用 LARGE_* 是因為未來會再加 SMALL)
LARGE_MODEL_ID=google/gemma-4-26B-A4B-it
LARGE_MODEL_NAME=gemma-large

# GPU 記憶體使用比例 (單一模型可以開大一點)
LARGE_GPU_MEM_UTIL=0.85

# 最大 context 長度
LARGE_MAX_LEN=8192

# 一次 batch 內可塞的最大 token 數
# Gemma 多模態單張圖至少 ~2496 tokens，預設 2048 會炸；建議跟 MAX_LEN 對齊
LARGE_MAX_BATCHED=8192

# Nginx 對外 port (唯一 entry，預設 80；若 80 已被佔用改成 8080 等)
NGINX_PORT=80
